{
  "name": "paxmed",
  "version": "1.0.0",
  "description": "India prescription medicine price comparison (PaxMed)",
  "author": "Prabhudatta Choudhury",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "dev:local": "node server/scripts/dev-local.js",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d db",
    "db:migrate": "node server/db/migrate.js",
    "db:backfill-lab-prices": "node server/scripts/backfill-lab-prices-all-cities.js",
    "db:seed": "node server/db/seed.js",
    "db:import-dataset": "node server/scripts/import-paxmed-dataset.js",
    "db:load-full-data": "node server/scripts/load-postgres-data.js",
    "test:ui-abha": "node e2e/abha-profile.ui.mjs",
    "test:ui-discount": "node e2e/discount-compare.ui.mjs",
    "test:ui-labs-suggest": "node e2e/labs-diagnostics-suggestions.ui.mjs",
    "generate:partner-templates": "node server/scripts/generate-partner-price-templates.mjs",
    "loadtest:k6": "k6 run loadtest/k6/paxmed-stress.js",
    "loadtest:node": "node loadtest/node-stress.mjs",
    "test:prescription-ocr-samples": "node server/scripts/test-prescription-ocr-uploads.mjs",
    "test": "node --test tests/*.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "playwright": "^1.58.2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.2",
    "pg": "^8.20.0",
    "pg-connection-string": "^2.12.0",
    "redis": "^5.11.0",
    "tesseract.js": "^5.1.1",
    "xlsx": "^0.18.5"
  }
}
